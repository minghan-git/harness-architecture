        direction TB
        C1["Gather"]
        C2["Validate"]
        C1 --> C2
    end

    subgraph S2["階段 2 · Analyze"]
        direction TB
        A1["Multi-perspective<br/>(parallel)"]
        A2["Critic"]
        A1 --> A2
    end

    subgraph S3["階段 3 · Create"]
        direction TB
        CR1["Ideate"]
        CR2["Evaluate"]
        CR1 --> CR2
    end

