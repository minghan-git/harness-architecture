    S1 -->|"⚡ eval"| S2
    S2 -->|"🤖 eval"| S3
    S3 -->|"📏 eval"| S4
    S4 -->|"🎯 eval"| CMD["Commander"]

    S2 -.->|"❌ ≤3"| S1
